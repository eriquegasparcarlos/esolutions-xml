{
    "name": "esolutions/xml",
    "description": "Generacion, firma, validacion y envio SUNAT/OSE de XML UBL para comprobantes electronicos (Peru)",
    "type": "library",
    "license": "proprietary",
    "keywords": ["sunat", "ubl", "xml", "facturacion-electronica", "peru", "cpe"],
    "authors": [
        {
            "name": "Carlos Erique Gaspar",
            "email": "eriquegasparcarlos@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-dom": "*",
        "ext-libxml": "*",
        "ext-openssl": "*",
        "ext-soap": "*",
        "ext-zip": "*",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "robrichards/xmlseclibs": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "ESolutions\\Xml\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "ESolutions\\Xml\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ESolutions\\Xml\\XmlServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "require-dev": {
        "orchestra/testbench": "^11.1",
        "phpunit/phpunit": "^13.2"
    }
}

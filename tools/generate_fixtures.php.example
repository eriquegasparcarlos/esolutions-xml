// ── Ejecutar ────────────────────────────────────────────────────────────
$tipoDoc = fn($t) => ['01' => '01', '03' => '03', '07' => '07', '08' => '08'][$t];
foreach ($V as $label => $payload) {
    $tipo = $payload['document']['document_type_id'];
    $res = $gen->generate($tipo, $payload);
    $file = $dir . '/' . preg_replace('/[^A-Z0-9]+/i', '_', $label) . '.xml';
    if ($res->xml) file_put_contents($file, $res->xml);
    $xsd = $res->isOk() ? 'XSD OK' : ('XSD FALLA: ' . ($res->validation->firstMessage() ?? ''));
    $emits = [];
    if ($res->xml) {
        $r = $validator->validate($res->xml, $tipo);
        foreach ($r->errors as $e) $emits[$e->path] = ($emits[$e->path] ?? 0) + 1;
    }
    printf("%-30s | %-9s | reglas: %d", $label, $xsd, array_sum($emits));
    if ($emits) { echo ' -> '; foreach ($emits as $c => $n) echo $c . 'x' . $n . ' '; }
    echo "\n";
}
echo "\nTotal: " . count($V) . " ejemplos en $dir\n";

    L(100, '10', 'Gravado'), L(50, '20', 'Exonerado'), L(30, '30', 'Inafecto'),
]);
// FACTURAS con estructuras (reusando el motor de INV para consistencia)
$V['FAC-02 con descuento global'] = INV($facBase, '01', 'F001-102', [L(100, '10', 'Servicio')], [
    'discounts' => fn(&$d) => $d['discounts'] = [['discount_type_id' => '02', 'factor' => 0.1, 'amount' => 10, 'base' => 100]],
    'total_discount_no_base' => 10.0,
    'total_payable' => 108.0,
]);
$V['FAC-03 con detraccion'] = INV($facBase, '01', 'F001-103', [L(1000, '10', 'Servicio sujeto a detraccion')], [
    'operation_type_id' => '1001',
    'detraction' => fn(&$d) => $d['detraction'] = ['payment_method_type_id' => '001', 'bank_account' => '00-099-025344', 'detraction_type_id' => '037', 'percentage' => 12, 'amount_pen' => 141.6],
    'legends' => fn(&$d) => $d['legends'][] = ['code' => '2006', 'value' => 'Operacion sujeta a detraccion'],
]);
$V['FAC-05 a credito'] = INV($facBase, '01', 'F001-105', [L(100, '10', 'Servicio')], [
    'payment_condition_id' => '02', 'fee_total' => 118.0,

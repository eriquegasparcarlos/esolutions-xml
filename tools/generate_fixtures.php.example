// ── Helper: línea consistente por afectación ────────────────────────────
// $afect: 10 gravado, 20 exonerado, 30 inafecto, 21 gratuito, 40 exportación
function L(float $valor, string $afect, string $name, float $qty = 1, float $icbper = 0, float $isc = 0): array {
    $igv = ($afect === '10') ? round($valor * 0.18, 2) : 0.0;
    $gratuito = ($afect === '21');
    $unit = round($valor / $qty, 6);
    return [
        'unit_type_id' => 'NIU', 'quantity' => $qty,
        'total_value' => $gratuito ? 0.0 : $valor,
        'price_type_id' => $gratuito ? '02' : '01',
        'price_amount_01' => $gratuito ? 0.0 : ($afect === '10' ? round($unit * 1.18, 6) : $unit),
        'price_amount_02' => $gratuito ? $unit : $unit,
        'unit_value' => $unit,
        'charges' => [], 'discounts' => [],
        'total_taxes' => $igv + $isc + $icbper,
        'total_isc' => $isc, 'total_base_isc' => $isc > 0 ? $valor : 0, 'percentage_isc' => $isc > 0 ? 10 : 0, 'system_isc_type_id' => $isc > 0 ? '01' : null,
        'total_base_igv' => $valor, 'total_igv' => $igv, 'percentage_igv' => ($afect === '10') ? 18 : 0,
        'affectation_igv_type_id' => $afect,
        'total_other_taxes' => 0, 'total_base_other_taxes' => 0, 'percentage_other_taxes' => 0,
        'total_plastic_bag_taxes' => $icbper, 'amount_plastic_bag_taxes' => $icbper > 0 ? 0.5 : 0,
        'name_parts' => [$name], 'internal_id' => null, 'item_code' => null,
        'accommodation_attributes' => [], 'attributes' => [],
    ];
}

// ── Helper: arma payload con totales reconciliados ──────────────────────
function INV(array $base, string $tipo, string $id, array $lines, array $ov = []): array {
    $p = $base;
    $d = &$p['document'];
    $d['id'] = $id;
    $d['document_type_id'] = $tipo;
    $d['items'] = $lines;
    // sumas por tipo de afectación
    $sum = fn($k) => array_sum(array_map(fn($l) => $l[$k], $lines));
    $byAfect = fn($a, $k) => array_sum(array_map(fn($l) => $l['affectation_igv_type_id'] === $a ? $l[$k] : 0, $lines));
    $d['total_taxed'] = $byAfect('10', 'total_value');
    $d['total_exonerated_init'] = $byAfect('20', 'total_value');
    $d['total_unaffected_init'] = $byAfect('30', 'total_value');
    $d['total_exportation_init'] = $byAfect('40', 'total_value');
    $d['total_free'] = array_sum(array_map(fn($l) => $l['affectation_igv_type_id'] === '21' ? $l['unit_value'] * $l['quantity'] : 0, $lines));
    $d['total_igv'] = $sum('total_igv');
    $d['total_isc'] = $sum('total_isc');
    $d['total_icbper'] ?? null;
    $d['total_plastic_bag_taxes'] = $sum('total_plastic_bag_taxes');
    $d['total_other_taxes'] = 0;
    $d['total_base_other_taxes'] = 0;
    $d['total_igv_free'] = 0.0;
    $d['total_prepayment_unaffected'] = 0.0;
    $d['total_prepayment_exonerated'] = 0.0;
    $d['total_taxes'] = $d['total_igv'] + $d['total_isc'] + $d['total_plastic_bag_taxes'];
    $d['total_value'] = $sum('total_value');
    $d['total_discount_no_base'] = 0.0;
    $d['total_charge'] = 0.0;
    $d['total_prepayment'] = 0.0;
    $d['total_payable'] = round($d['total_value'] + $d['total_taxes'], 2);
    $d['discounts'] = [];
    $d['charges'] = [];
    $d['detraction'] = null; $d['retention'] = null; $d['perception'] = null;
    $d['payment_condition_id'] = '01'; $d['fee'] = []; $d['fee_total'] = 0.0;
    $d['operation_type_id'] = ($tipo === '01') ? '0101' : '0101';
    $d['operation_type_is_exportation'] = false;
    foreach ($ov as $k => $v) { if (is_callable($v)) $v($d); else $d[$k] = $v; }
    return $p;
}

$V = [];
// FACTURAS por afectación
$V['FAC-01 gravada'] = INV($facBase, '01', 'F001-101', [L(100, '10', 'Servicio gravado')]);
$V['FAC-06 exonerada'] = INV($facBase, '01', 'F001-106', [L(100, '20', 'Consulta exonerada')]);
$V['FAC-07 inafecta'] = INV($facBase, '01', 'F001-107', [L(100, '30', 'Servicio inafecto')]);

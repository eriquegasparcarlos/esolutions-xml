$V['FAC-10 con ICBPER'] = INV($facBase, '01', 'F001-110', [L(100, '10', 'Producto', 1, 2.0)]);
$V['FAC-11 con ISC'] = INV($facBase, '01', 'F001-111', [L(100, '10', 'Producto con ISC', 1, 0, 10.0)]);

]);
// BOLETAS
$V['BOL-01 gravada DNI'] = INV($bolBase, '03', 'B001-101', [L(100, '10', 'Consulta')]);
$V['BOL-06 exonerada'] = INV($bolBase, '03', 'B001-106', [L(100, '20', 'Consulta exonerada')]);
// NOTAS DE CREDITO
$V['NC-01 anulacion'] = INV($facBase, '07', 'FC01-1', [L(100, '10', 'Servicio')], [

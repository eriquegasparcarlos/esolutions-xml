// NOTAS DE DEBITO
$V['ND-01 intereses'] = INV($facBase, '08', 'FD01-1', [L(50, '10', 'Intereses por mora')], [
    'affected_document' => ['id' => 'F001-101', 'document_type_id' => '01', 'date_of_issue' => '2026-07-14'],
